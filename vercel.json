{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  
  "functions": {
    "app.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  
  "routes": [
    { "src": "^/(?:api|entities|explore|youtube|jiosaavn|api-docs|health)(?:/.*)?$", "dest": "/app.js" }
  ],
  
  "env": {
    "NODE_ENV": "production"
  }
}
